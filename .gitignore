# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.nyc_output/
/test-results/
/playwright-report/
/blob-report/
/junit*.xml

# next.js
/.next/
/out/

# production
/build
/dist/
/storybook-static/

# misc
.DS_Store
*.pem
*.pid
*.seed
*.heapsnapshot
*.har
*.trace.zip
*.webm

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# IDE and AI tools
.vscode/
.idea/
.claude/
.cursor/
.gemini/
.artifacts/
.agent/
.shared/
.codex/
# local Codex task state; historical tracked task artifacts remain tracked
.codex-tasks/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# logs
/logs
*.log
reports/
screenshots/
downloads/

# environment variables
.env
.env.local
.env.test
.env.development
.env.production
.env.staging
.env.preview
.env.*.local
!.env.example
docker-logs/

# database
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
prisma/data/
.temporal/
temporalite.db*
temporal-data/

# uploads (user data)
uploads/
/data/

certificates

# local temporary snapshots for old-version verification
.tmp-old-snapshot-*/

# temporary files
tmp/
/.tmp/
/.tmp-*/
/.tmp_*
scripts/tmp-*

# internal AI agent config (not for public)
agent/

# local tool caches
.cache/
.turbo/
.parcel-cache/
.eslintcache
.npm/
.pnpm-store/

# GitHub CI workflows (internal)
# .github/ — 只保留 workflows，忽略其他
.github/*
!.github/workflows/
